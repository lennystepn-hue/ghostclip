{
  "name": "@ghostclip/desktop",
  "version": "0.2.0",
  "private": true,
  "description": "AI-powered Clipboard Manager — smart tagging, vision OCR, encrypted sync",
  "author": {
    "name": "Lenny Enderle",
    "email": "lenny@ghostclip.app"
  },
  "homepage": "https://github.com/lennystepn-hue/ghostclip",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder"
  },
  "dependencies": {
    "@ghostclip/shared": "workspace:*",
    "@ghostclip/crypto": "workspace:*",
    "@ghostclip/ai-client": "workspace:*",
    "@ghostclip/ui": "workspace:*",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron-toolkit/preload": "^3.0.0",
    "socket.io-client": "^4.8.0",
    "electron-updater": "^6.3.0",
    "better-sqlite3": "^11.7.0"
  },
  "build": {
    "appId": "com.ghostclip.app",
    "productName": "GhostClip",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "lennystepn-hue",
      "repo": "ghostclip"
    },
    "artifactName": "GhostClip-${version}-${arch}.${ext}",
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "resources/icon.png",
      "category": "Utility",
      "maintainer": "Lenny Enderle <lenny@ghostclip.app>",
      "executableName": "ghostclip"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "resources/icon.png",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": ["nsis"],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.468.0",
    "recharts": "^2.15.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "typescript": "^5.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/better-sqlite3": "^7.6.0"
  }
}
